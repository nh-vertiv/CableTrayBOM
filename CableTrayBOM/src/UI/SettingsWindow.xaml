<Window x:Class="CableTrayBOM.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Joint Material Settings" 
        Height="680" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6FA">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#4472C4"/>
        <SolidColorBrush x:Key="SubtleBrush" Color="#636E72"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#4472C4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Joint Material Quantities per Element" 
                   FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                   Margin="0,0,0,12"/>

        <TabControl Grid.Row="1" x:Name="tabCategories">
            
            <!-- Mesh Cable Tray Tab -->
            <TabItem Header="Mesh Tray (Support Channel)">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Per Support (Mupro):" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgMeshTraySupport" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True" 
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Support" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Per Connection (between segments):" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgMeshTrayConnection" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Connection" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Mesh Cable Tray Console Tab -->
            <TabItem Header="Mesh Tray (Console)">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Per Support:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgMeshConsoleSupport" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Support" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Per Connection:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgMeshConsoleConnection" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Connection" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Cable Ladder Tab -->
            <TabItem Header="Cable Ladder">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Per Support:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgLadderSupport" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Support" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Per Connection:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgLadderConnection" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Connection" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Perforated Tray Tab -->
            <TabItem Header="Perforated Tray">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Per Support:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgPerfSupport" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Support" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Per Connection:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgPerfConnection" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Connection" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Non-Perforated Tray Tab -->
            <TabItem Header="Non-Perf. Tray">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Per Support:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgNonPerfSupport" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Support" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Per Connection:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgNonPerfConnection" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Connection" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Fiber Tray Tab -->
            <TabItem Header="Fiber Tray">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Per Support:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgFiberSupport" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Support" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Per Connection:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgFiberConnection" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Connection" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Fixtures Tab -->
            <TabItem Header="Fixtures &amp; JBs">
                <ScrollViewer Margin="8">
                    <StackPanel>
                        <TextBlock Text="Lighting - Support Channel Mounting:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgLightingChannel" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per Fixture" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Junction Box - Mesh Tray Mounting:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgJBMeshTray" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column" Margin="0,0,0,16">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per JB" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Junction Box - Panel Mounting:" FontWeight="SemiBold" FontSize="13" Margin="0,4,0,8"/>
                        <DataGrid x:Name="dgJBPanel" AutoGenerateColumns="False" 
                                  CanUserAddRows="True" CanUserDeleteRows="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Material Name" Binding="{Binding Key}" Width="*"/>
                                <DataGridTextColumn Header="Qty per JB" Binding="{Binding Value}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Flexible Conduit Length per Fixture (mm):" FontWeight="SemiBold" FontSize="13" Margin="0,16,0,4"/>
                        <TextBox x:Name="txtConduitLength" Text="400" Width="100" HorizontalAlignment="Left"
                                 Padding="6,4" FontSize="13"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Reset to Defaults" Style="{StaticResource ActionButton}" 
                    Background="#DFE6E9" Foreground="#2D3436"
                    Click="BtnReset_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Style="{StaticResource ActionButton}" 
                    Background="#DFE6E9" Foreground="#2D3436"
                    Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save Settings" Style="{StaticResource ActionButton}" 
                    Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
